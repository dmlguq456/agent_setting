      "output_path": "`notes/_layer2/notes/` plus digest",
      "layer": "L3"
    },
    {
      "slug": "loop__oncall",
      "name": "On-call",
      "mono": "oncall",
      "type": "time",
      "schedule": "Cron at 05:37",
      "blurb": "Overnight patrol; corroborate at most two memory-backed harness incidents and exact-deduplicate evidence into the proposal inbox, then report",
      "output_path": "`notes/oncall/<date>.md` plus offline proposal evidence",
      "layer": "L3"
    },
    {
      "slug": "loop__runtime-watch",
      "name": "Runtime watch",
      "mono": "runtime-watch",
      "type": "event",
      "schedule": "At most daily, or manually after a runtime-currentness event",
      "blurb": "Fingerprint authoritative sources and probe local CLI/projection/usage helpers; report or propose only, with no policy auto-edits",
      "output_path": "`notes/runtime-watch/<date>.md`",
      "layer": "L4"
    },
    {
      "slug": "loop__study",
      "name": "Study",
      "mono": "study",
      "type": "time",
      "schedule": "Sunday cron at 06:17",
      "blurb": "Survey recent agent-engineering work and adapter changes, compare with the harness, and produce proposals only; critical items may include an automatic draft",
      "output_path": "`notes/study/<date>.md`",
      "layer": "L4"
    }
