import hashlib
import json
import subprocess
import sys
import tempfile
from pathlib import Path
from tools.fleet.token_experiment import ARMS, config_fingerprint, manifest_sha256

root = Path.cwd()
fixture = root / "tools/fleet/tests/fixtures/token_experiment"
manifest_path = fixture / "manifest.json"
replay_path = fixture / "replay.json"
cli = root / "utilities/token-budget-experiment.py"
manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
manifest_hash = manifest_sha256(manifest)

replay_cmd = [sys.executable, str(cli), "replay", "--manifest", str(manifest_path), "--input", str(replay_path)]
replay_a = subprocess.run(replay_cmd, check=True, capture_output=True).stdout
replay_b = subprocess.run(replay_cmd, check=True, capture_output=True).stdout
assert replay_a == replay_b
replay_result = json.loads(replay_a)
assert replay_result["synthetic_non_evidentiary"] is True
assert replay_result["production_enabled"] is False

workloads = []
for index in range(30):
    workload_id = f"synthetic-{index:03d}"
    declaration = {
        "experiment_id": "synthetic-cli-smoke",
        "workload_id": workload_id,
        "stratum": "code",
        "prompt_sha256": "1" * 64,
        "artifact_bundle_sha256": "2" * 64,
        "rubric_version": "rubric-v1",
        "rubric_sha256": "3" * 64,
        "required_checks": ["required-v1"],
        "safety_checks": ["safety-v1"],
        "model_id": "synthetic-model",
        "runtime_id": "synthetic-runtime",
        "runtime_config_sha256": "4" * 64,
        "reasoning_effort": "high",
        "intensity": "thorough",
        "dispatch_depth": 2,
        "qa_contract": "thorough-code",
        "seed": None,
        "arm_order": list(ARMS),
    }
    fingerprint = config_fingerprint(declaration)
    deltas = {"control": 120, "static": 100, "dynamic": 80}
    results = []
    for arm in ARMS:
        emissions = 0 if arm == "control" else 1
        results.append({
            "experiment_id": declaration["experiment_id"],
            "workload_id": workload_id,
            "arm": arm,
            "manifest_sha256": manifest_hash,
            "config_fingerprint": fingerprint,
            "status": "complete",
            "exclusion_reason": None,
            "session_counter_status": "observed",
            "session_total_tokens_start": 1000,
            "session_total_tokens_end": 1000 + deltas[arm],
            "session_token_delta": deltas[arm],
            "hook_invocations": 2,
            "zero_injections": 2 - emissions,
            "emissions": emissions,
            "directive_utf8_bytes_total": 0 if arm == "control" else 154,
            "directive_exact_tokens": None,
            "exact_tokenizer_provenance": None,
            "required_checks_pass": True,
            "safety_checks_pass": True,
            "hard_regression": False,
            "quality_score": 0.9,
            "quality_evaluator_id": "frozen-rubric-v1",
        })
    workloads.append({"declaration": declaration, "results": results})
payload = {"experiment_id": "synthetic-cli-smoke", "workloads": workloads}

with tempfile.TemporaryDirectory(prefix="token-experiment-cli-") as tmp:
    input_path = Path(tmp) / "synthetic-evaluate.json"
    input_path.write_text(json.dumps(payload, ensure_ascii=False, sort_keys=True), encoding="utf-8")
    evaluate_cmd = [sys.executable, str(cli), "evaluate", "--manifest", str(manifest_path), "--input", str(input_path)]
    evaluate_a = subprocess.run(evaluate_cmd, check=True, capture_output=True).stdout
    evaluate_b = subprocess.run(evaluate_cmd, check=True, capture_output=True).stdout

assert evaluate_a == evaluate_b
evaluation = json.loads(evaluate_a)
assert evaluation["complete_triplets"] == 30
assert evaluation["verdict"] == "eligible_for_user_review"
assert evaluation["adoption_decision"] == "pending_user_decision"
assert evaluation["production_dynamic_enabled"] is False
assert all(value == "pass" for value in evaluation["gates"].values())
assert evaluation["bootstrap"] == {"resamples": 10000, "seed": 20260713}
assert evaluation["metrics"]["directive_utf8_bytes_by_arm"] == {"control": 0, "static": 4620, "dynamic": 4620}
assert evaluation["metrics"]["emissions_by_arm"] == {"control": 0, "static": 30, "dynamic": 30}
print("replay_sha256=" + hashlib.sha256(replay_a).hexdigest())
print("evaluate_sha256=" + hashlib.sha256(evaluate_a).hexdigest())
print("replay_byte_identical=1 evaluate_byte_identical=1")
print("fixtures_synthetic_non_evidentiary=1 adoption_decision=pending_user_decision production_dynamic_enabled=0")
print("complete_triplets=30 verdict=eligible_for_user_review bootstrap_resamples=10000 bootstrap_seed=20260713")
print("directive_utf8_bytes_by_arm=control:0,static:4620,dynamic:4620 emissions_by_arm=control:0,static:30,dynamic:30")
