COMMAND: adapters/codex/bin/preflight.sh verification-runner --timeout 120 -- bash -lc 'set -u
rc=0
arg_drift=0
names="analyze-project analyze-user audit autopilot-apply autopilot-code autopilot-design autopilot-draft autopilot-lab autopilot-note autopilot-refine autopilot-research autopilot-ship autopilot-spec code-execute code-plan code-refine code-report code-test design-components design-review design-tokens draft-refine draft-strategy post-it sync-skills"
for n in $names; do
  shint=$(sed -n '"'"'1,/^---$/p'"'"' "adapters/claude/skills/$n/SKILL.md" | sed -n '"'"'s/^argument-hint: //p'"'"' | head -1)
  shint=${shint#\"}; shint=${shint%\"}
  cint=$(sed -n '"'"'s/^| Argument shape | `\(.*\)` |$/\1/p'"'"' "capabilities/$n.md" | head -1)
  if [ "$shint" != "$cint" ]; then printf "ARG_DRIFT\t%s\nskill=%s\ncapability=%s\n" "$n" "$shint" "$cint"; rc=1; arg_drift=$((arg_drift+1)); fi
done
echo "argument_shape_drift_count=$arg_drift"
echo "== stale separate QA-axis language in touched capability contracts =="
files=""
for n in $names; do files="$files capabilities/$n.md"; done
qa_files=$(rg -l -- '"'"'--qa|QA level is an assurance override|Default `--qa'"'"' $files | sort || true)
qa_count=$(printf "%s\n" "$qa_files" | sed '"'"'/^$/d'"'"' | wc -l | tr -d " ")
printf "%s\n" "$qa_files"
echo "stale_qa_axis_file_count=$qa_count"
[ "$qa_count" = 0 ] || rc=1
echo "== autopilot-ship semantic contract =="
rg -n '"'"'첫 ship setup|env|domain|migration|실제 배포 명령은 사용자 직접|재호출 가능'"'"' capabilities/autopilot-ship.md
exit $rc'
EXIT: 1
