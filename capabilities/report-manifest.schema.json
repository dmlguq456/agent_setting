{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "capabilities/report-manifest.schema.json",
  "title": "Portable report media manifest",
  "type": "object",
  "required": ["schema_version", "outputs", "summary_stats", "house_parameters", "media", "visual_evidence"],
  "properties": {
    "schema_version": {"const": 1},
    "outputs": {
      "type": "object",
      "required": ["markdown", "html"],
      "properties": {
        "markdown": {"$ref": "#/$defs/file"},
        "html": {"$ref": "#/$defs/file"}
      },
      "additionalProperties": false
    },
    "summary_stats": {"type": "object", "minProperties": 1},
    "house_parameters": {
      "type": "object",
      "required": ["sample_rate_hz", "frequency_band_hz"],
      "properties": {
        "sample_rate_hz": {"const": 48000},
        "frequency_band_hz": {"type": "array", "prefixItems": [{"const": 0}, {"const": 24000}], "items": false}
      }
    },
    "media": {"type": "array", "minItems": 1},
    "visual_evidence": {"type": "array", "minItems": 1}
  },
  "$defs": {
    "file": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {"path": {"type": "string"}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
    }
  }
}
