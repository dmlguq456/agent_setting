{
  "schema_version": 2,
  "intensities": [
    "direct",
    "quick",
    "standard",
    "strong",
    "thorough",
    "adversarial"
  ],
  "execution_topologies": [
    "inline",
    "one-shot-owner",
    "transactional-owner",
    "map-reduce",
    "staged",
    "staged+resource"
  ],
  "worker_kinds": [
    "capability-owner",
    "pipeline-stage",
    "review-worker",
    "map-worker",
    "resource-runner"
  ],
  "transports": [
    "headless",
    "interactive"
  ],
  "tracking_values": [
    "tracked",
    "untracked"
  ],
  "tracked_gate_evidence": [
    "spec_read",
    "drift_verdict",
    "workflow_mode",
    "artifact_guard"
  ],
  "guard_preconditions": [
    "artifact-order-prechecked"
  ],
  "artifact_owners": {
    "spec": "autopilot-spec"
  },
  "rollout": {
    "route_compiler": "report-only",
    "legacy_low_level_dispatch": true
  },
  "inline_reasons": [
    "atomic-direct",
    "nonseparable-transaction",
    "runtime-unavailable",
    "dispatch-infra-self-modification",
    "user-restricted"
  ],
  "gate_command": "python3 utilities/capability-route.py complete --route <route> --node <node> --evidence <path> --jobs <canonical-jobs.log> --attempt-id <exact-attempt-id>",
  "recipes": [
    {
      "capability": "autopilot-apply",
      "modes": [
        "default"
      ],
      "topology_class": "staged",
      "direct_predicates": [
        "atomic-outcome",
        "known-scope",
        "no-shared-contract",
        "no-resource-run",
        "no-artifact-handoff",
        "no-independent-verifier",
        "focused-verification"
      ],
      "promotion_signals": [
        "shared-contract",
        "independent-verifier",
        "human-gate",
        "stage-resume"
      ],
      "quick": {
        "topology": "one-shot-owner",
        "worker_kind": "capability-owner",
        "write_scope": [
          "target-artifact",
          "apply-log/**"
        ],
        "owner_dispatch_depth": 1,
        "max_dispatch_depth": 1
      },
      "standard_plus": {
        "topology": "staged",
        "nodes": [
          {
            "id": "apply",
            "kind": "pipeline-stage",
            "depends_on": [],
            "role": "fast implementer",
            "inputs": [
              "cheatsheet",
              "target-artifact"
            ],
            "outputs": [
              "applied-artifact",
              "apply-log"
            ],
            "write_scope": [
              "target-artifact",
              "apply-log/**"
            ],
            "resource_class": "normal",
            "completion_gate": "apply-hash",
            "dispatch_depth": 2,
            "fallback_hops": [
              "same-harness-headless",
              "cross-harness-headless",
              "inline"
            ]
          },
          {
            "id": "verify",
            "kind": "review-worker",
            "depends_on": [
              "apply"
            ],
            "role": "fast reviewer",
            "inputs": [
              "applied-artifact",
              "apply-log"
            ],
            "outputs": [
              "reviews/apply-verdict.json"
            ],
            "write_scope": [
              "reviews/apply/**"
            ],
            "resource_class": "normal",
            "completion_gate": "apply-verify",
            "dispatch_depth": 2,
            "fallback_hops": [
              "same-harness-headless",
              "cross-harness-headless",
              "native-subagent",
              "inline"
            ]
          },
          {
            "id": "handback",
            "kind": "capability-owner",
            "depends_on": [
              "verify"
            ],
            "role": "deep orchestrator",
            "inputs": [
              "reviews/apply-verdict.json"
            ],
            "outputs": [
              "handback.json"
            ],
            "write_scope": [
              "handback.json"
            ],
            "resource_class": "normal",
            "completion_gate": "apply-handback",
            "dispatch_depth": 1,
            "fallback_hops": [
              "same-harness-headless",
              "cross-harness-headless",
              "inline"
            ]
          }
        ],
        "owner_dispatch_depth": 1,
        "max_dispatch_depth": 2
      },
      "completion_gates": [
        "apply-hash",
        "apply-verify",
        "apply-handback"
      ],
      "human_gates": [
        "explicit-handback"
      ],
      "resume_retry_boundaries": [
        "apply",
        "verify"
      ]
    },
