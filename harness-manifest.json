{
  "schema_version": 1,
  "product": {
    "id": "agent-harness",
    "manifest_version": "1.0.0",
    "default_profile": "builder",
    "runtimes": [
      "claude",
      "codex",
      "opencode"
    ]
  },
  "capabilities": {
    "analyze-project": {
      "group": "pre",
      "family": "pre",
      "modes": [
        "code",
        "paper",
        "doc"
      ],
      "summary": "Upfront analysis that structures primary code, paper, and document materials for downstream work.",
      "argument_shape": "[--mode code|paper|doc] [<scope/target/input-folder>] [--skip-qa]",
      "requires": {
        "capabilities": [],
        "roles": [
          "material-team",
          "qa-team",
          "research-team"
        ]
      }
    },
    "analyze-user": {
      "group": "pre",
      "family": "pre",
      "modes": [
        "init",
        "update"
      ],
      "summary": "Create or update a cross-project user-preference profile from coding, writing, and analysis patterns.",
      "argument_shape": "<aspect> [--source <path>] [--mode init|update] [--from discover|analyze|verify|qa|output|summary] [--user-refine]",
      "requires": {
        "capabilities": [],
        "roles": [
          "editorial-team",
          "qa-team",
          "research-team"
        ]
      }
    },
    "audit": {
      "group": "ops",
      "family": "ops",
      "modes": [],
      "summary": "Read-oriented post-run inspection for artifact drift, inconsistency, and omissions.",
      "argument_shape": "<artifact_path> [--scope auto|facts|style|structure|cross-ref|coverage|all] [--read-only] [--report-only] [--no-fact-check]",
      "requires": {
        "capabilities": [],
        "roles": [
          "qa-team"
        ]
      }
    },
    "autopilot-apply": {
      "group": "entry",
      "family": "doc",
      "modes": [],
      "summary": "Apply a cheatsheet draft to the real source artifact and verify the result.",
      "argument_shape": "\"<cheatsheet hint / task>\" [--target latex] [--source <path-to-real-source>] [--isolation branch|worktree] [--from preflight|apply|verify|handback]",
      "requires": {
        "capabilities": [],
        "roles": [
          "dev-team",
          "qa-team"
        ]
      }
    },
    "autopilot-code": {
      "group": "entry",
      "family": "code",
      "modes": [
        "dev",
        "debug",
        "audit"
      ],
      "summary": "Code-work entrypoint that detects spec context and closes the plan→execute→test→report loop.",
      "argument_shape": "--mode dev|debug <task/plan/error description> [--from <step>] [--intensity direct|quick|standard|strong|thorough|adversarial] [--user-refine]",
      "requires": {
        "capabilities": [
          "code-plan",
          "code-execute",
          "code-test",
          "code-report",
          "code-refine"
        ],
        "roles": [
          "dev-team",
          "editorial-team",
          "plan-team",
          "qa-team"
        ]
      }
    },
    "autopilot-design": {
      "group": "entry",
      "family": "design",
      "modes": [],
      "summary": "Visual-design pipeline coordinating references→tokens→components→review→handoff.",
      "argument_shape": "<design task or app path> [--scope ui|webapp|slide|icon|diagram|mixed] [--artifact standalone|project] [--from <phase>] [--intensity direct|quick|standard|strong|thorough|adversarial]",
      "requires": {
        "capabilities": [
          "design-init",
          "design-refs",
          "design-tokens",
          "design-components",
          "design-review",
          "design-handoff"
        ],
        "roles": [
          "design-team"
        ]
      }
    },
    "autopilot-draft": {
      "group": "entry",
      "family": "doc",
      "modes": [
        "paper",
        "presentation",
        "doc"
      ],
      "summary": "Document-drafting pipeline that produces an applicable artifact through strategy, drafting, verification, and editing.",
      "argument_shape": "<task description> [--mode paper|presentation|doc] [--intensity direct|quick|standard|strong|thorough|adversarial] [--user-refine] [--no-clarify] [--from analyze|strategy|strategy-refine|draft|draft-refine|finalize]",
      "requires": {
        "capabilities": [
          "draft-strategy",
          "draft-refine"
        ],
        "roles": [
          "editorial-team",
          "qa-team",
          "research-team"
        ]
      }
    },
    "autopilot-lab": {
      "group": "entry",
      "family": "code",
      "modes": [
        "setup",
        "eval"
      ],
      "summary": "Rapid experiment prototyping around training setup and checkpoint evaluation/analysis.",
      "argument_shape": "<task description> [--mode setup|eval|auto] [--parent <slug>] [--ref <similar-model-path>] [--intensity direct|quick|standard|strong|thorough|adversarial] [--report] [--from spec|scaffold|run|eval|summary]",
      "requires": {
        "capabilities": [],
        "roles": [
          "dev-team",
          "qa-team"
        ]
      }
    },
    "autopilot-note": {
      "group": "entry",
      "family": "ops",
      "modes": [],
      "summary": "Route and note artifacts, producing digests and triage proposals.",
      "argument_shape": "[--scope today|yesterday|since <date>|all] [--target <notes-root>] [--dry-run] [--intensity direct|quick|standard|strong|thorough|adversarial] [--digest-only] [--triage-only] [--source <list>]",
      "requires": {
        "capabilities": [],
        "roles": [
          "editorial-team"
        ]
      }
    },
    "autopilot-refine": {
      "group": "entry",
      "family": "doc",
      "modes": [],
      "summary": "Correct and update existing document/research artifacts while preserving snapshots and change history.",
      "argument_shape": "\"<prompt>\" [--intensity direct|quick|standard|strong|thorough|adversarial] [--review-only | --memo <file>] [--confirm] [--no-fact-check] [--no-style-audit]",
      "requires": {
        "capabilities": [],
        "roles": [
          "editorial-team",
          "qa-team",
          "research-team"
        ]
      }
    },
    "autopilot-research": {
      "group": "entry",
      "family": "pre",
      "modes": [
        "academic",
        "technology",
        "market"
      ],
      "summary": "Shared upfront research that surveys academic, technology, or market sources before downstream routing.",
      "argument_shape": "<query> [--mode academic|technology|market] [--depth shallow|medium|deep] [--intensity direct|quick|standard|strong|thorough|adversarial] [--no-clarify] [--no-figures] [--from search|analyze|report]",
      "requires": {
        "capabilities": [],
        "roles": [
          "material-team",
          "qa-team",
          "research-team"
        ]
      }
    },
    "autopilot-ship": {
      "group": "entry",
      "family": "app",
      "modes": [],
      "summary": "Prepare application deployment/release setup and a ship checklist.",
      "argument_shape": "<task description (optional)> [--intensity direct|quick|standard|strong|thorough|adversarial]",
      "requires": {
        "capabilities": [],
        "roles": [
          "dev-team",
          "qa-team"
        ]
      }
    },
    "autopilot-spec": {
      "group": "entry",
      "family": "code",
      "modes": [
        "app",
        "library",
        "api",
        "cli",
        "research",
        "update"
      ],
      "summary": "Create or update requirements/blueprints while keeping `prd.md` as the only spec-change path.",
      "argument_shape": "<task description> [--mode auto|app|library|api|cli|research|update (comma-separated for multiple)] [--intensity direct|quick|standard|strong|thorough|adversarial] [--user-refine]",
      "requires": {
        "capabilities": [],
        "roles": [
          "design-team",
          "material-team",
          "plan-team",
          "qa-team"
        ]
      }
    },
    "code-execute": {
      "group": "sub",
      "family": "sub",
      "modes": [],
      "summary": "Execute a plan step by step, delegate implementation to the development role, and record an execution log.",
      "argument_shape": "<plan name or path>",
      "requires": {
        "capabilities": [],
        "roles": [
          "dev-team"
        ]
      }
    },
    "code-plan": {
      "group": "sub",
      "family": "sub",
      "modes": [],
      "summary": "Analyze code, write a detailed implementation plan, and run the plan-check gate at the rigor derived from intensity.",
      "argument_shape": "<task description> [--intensity direct|quick|standard|strong|thorough|adversarial]",
      "requires": {
        "capabilities": [],
        "roles": [
          "plan-team",
          "qa-team"
        ]
      }
    },
    "code-refine": {
      "group": "sub",
      "family": "sub",
      "modes": [],
      "summary": "Revise an existing plan using user notes, plan-check feedback, and verification-failure notes.",
      "argument_shape": "<plan name or path> [--intensity direct|quick|standard|strong|thorough|adversarial]",
      "requires": {
        "capabilities": [],
        "roles": [
          "plan-team"
        ]
      }
    },
    "code-report": {
      "group": "sub",
      "family": "sub",
      "modes": [],
      "summary": "Assemble code-cycle results into a user-facing report.",
      "argument_shape": "<plan name or path>",
      "requires": {
        "capabilities": [],
        "roles": [
          "editorial-team"
        ]
      }
    },
    "code-test": {
      "group": "sub",
      "family": "sub",
      "modes": [],
      "summary": "Verify implementation results in stages and record evidence.",
      "argument_shape": "<plan name, path, or test scope> [--intensity direct|quick|standard|strong|thorough|adversarial]",
      "requires": {
        "capabilities": [],
        "roles": [
          "qa-team"
        ]
      }
    },
    "design-components": {
      "group": "sub",
      "family": "sub",
      "modes": [],
      "summary": "Build UI components/mockups and preview artifacts.",
      "argument_shape": "<design path or app path>",
      "requires": {
        "capabilities": [],
        "roles": [
          "design-team"
        ]
      }
    },
    "design-handoff": {
      "group": "sub",
      "family": "sub",
      "modes": [],
      "summary": "Package design results as assets and specifications for development handoff.",
      "argument_shape": "<design path or app path>",
      "requires": {
        "capabilities": [],
        "roles": [
          "design-team",
          "editorial-team"
        ]
      }
    },
    "design-init": {
      "group": "sub",
      "family": "sub",
      "modes": [],
      "summary": "Bootstrap the design environment and state.",
      "argument_shape": "<design task description> [--scope ui|slide|icon|diagram|mixed]",
      "requires": {
        "capabilities": [],
        "roles": [
          "design-team"
        ]
      }
    },
    "design-refs": {
      "group": "sub",
      "family": "sub",
      "modes": [],
      "summary": "Collect external and user-provided visual references and create a brief.",
      "argument_shape": "<design task> [--design <path>] [--refs <image paths>] [--no-web]",
      "requires": {
        "capabilities": [],
        "roles": [
          "design-team",
          "material-team"
        ]
      }
    },
    "design-review": {
      "group": "sub",
      "family": "sub",
      "modes": [],
      "summary": "Review design output for quality, token-contract compliance, and breakage.",
      "argument_shape": "<design path or app path>",
      "requires": {
        "capabilities": [],
        "roles": [
          "design-team"
        ]
      }
    },
    "design-tokens": {
      "group": "sub",
      "family": "sub",
      "modes": [],
      "summary": "Define design tokens such as color, typography, and spacing.",
      "argument_shape": "<design path or app path>",
      "requires": {
        "capabilities": [],
        "roles": [
          "design-team"
        ]
      }
    },
    "draft-refine": {
      "group": "sub",
      "family": "sub",
      "modes": [],
      "summary": "Refine a draft by applying memo/review feedback to a document strategy or draft.",
      "argument_shape": "<strategy or draft name or path> [--intensity direct|quick|standard|strong|thorough|adversarial]",
      "requires": {
        "capabilities": [],
        "roles": [
          "editorial-team"
        ]
      }
    },
    "draft-strategy": {
      "group": "sub",
      "family": "sub",
      "modes": [
        "rebuttal",
        "paper",
        "review",
        "report",
        "proposal",
        "presentation"
      ],
      "summary": "Create an initial document strategy and evidence-based writing plan.",
      "argument_shape": "<mode> --inputs <comma-separated-paths> --output <artifact-dir> [--intensity direct|quick|standard|strong|thorough|adversarial] <task description>",
      "requires": {
        "capabilities": [],
        "roles": [
          "editorial-team",
          "research-team"
        ]
      }
    },
    "post-it": {
      "group": "ops",
      "family": "ops",
      "modes": [],
      "summary": "Store project/cross-project notes and handoffs in working memory.",
      "argument_shape": "[show] | add <category> <text> | resolve <hint> | decide <text> | handoff [--no-confirm] | sweep [--no-confirm] | promote [<hint>] [--scope project|user [<aspect>]]",
      "requires": {
        "capabilities": [],
        "roles": []
      }
    }
  },
  "roles": {
    "design-team": {
      "portable_role": "deep maker plus verifier",
      "responsibility": "Visual making, critique, and independent breakage verification"
    },
    "dev-team": {
      "portable_role": "fast implementer by default",
      "responsibility": "Implement backend/frontend/refactor/new-lib work through mode personas"
    },
    "editorial-team": {
      "portable_role": "deep maker / fast reviewer by mode",
      "responsibility": "User-facing wording, translation, polish, and review"
    },
    "external-adversary": {
      "portable_role": "external adversary plus orchestrator",
      "responsibility": "Independent hostile review through a different runtime/process"
    },
    "material-team": {
      "portable_role": "deep maker plus fast tool worker",
      "responsibility": "Fetch, extract, visualize, and analyze supporting materials"
    },
    "plan-team": {
      "portable_role": "deep maker",
      "responsibility": "Read source and artifacts, produce or refine implementation plans"
    },
    "qa-team": {
      "portable_role": "variable reviewer",
      "responsibility": "Read-only code, plan, test, ML, data, and security review"
    },
    "research-team": {
      "portable_role": "variable research reviewer",
      "responsibility": "Paper-grounded review, survey, fact-check, and adversarial claim verification"
    }
  },
  "modes": {
    "design/_design_rules": {
      "role": "design-team",
      "status": "adapter-coupled",
      "internal": true
    },
    "design/critic": {
      "role": "design-team",
      "status": "adapter-coupled"
    },
    "design/maker": {
      "role": "design-team",
      "status": "adapter-coupled"
    },
    "design/verifier": {
      "role": "design-team",
      "status": "adapter-coupled"
    },
    "dev/backend": {
      "role": "dev-team",
      "status": "portable-persona"
    },
    "dev/frontend": {
      "role": "dev-team",
      "status": "portable-persona"
    },
    "dev/new-lib": {
      "role": "dev-team",
      "status": "portable-persona"
    },
    "dev/refactor": {
      "role": "dev-team",
      "status": "portable-persona"
    },
    "editorial/polish": {
      "role": "editorial-team",
      "status": "portable-persona"
    },
    "editorial/review": {
      "role": "editorial-team",
      "status": "portable-persona"
    },
    "editorial/translate": {
      "role": "editorial-team",
      "status": "portable-persona"
    },
    "material/browser-fetch": {
      "role": "material-team",
      "status": "portable-with-tool-contract"
    },
    "material/data-script": {
      "role": "material-team",
      "status": "portable-with-tool-contract"
    },
    "material/figure-gen": {
      "role": "material-team",
      "status": "portable-with-tool-contract"
    },
    "material/pdf-extract": {
      "role": "material-team",
      "status": "portable-with-tool-contract"
    },
    "material/web-image-search": {
      "role": "material-team",
      "status": "portable-with-tool-contract"
    },
    "qa/code-review": {
      "role": "qa-team",
      "status": "portable-persona"
    },
    "qa/data-curate": {
      "role": "qa-team",
      "status": "portable-persona"
    },
    "qa/ml-debug": {
      "role": "qa-team",
      "status": "portable-persona"
    },
    "qa/plan-review": {
      "role": "qa-team",
      "status": "portable-persona"
    },
    "qa/security-review": {
      "role": "qa-team",
      "status": "portable-with-tool-contract"
    },
    "qa/test": {
      "role": "qa-team",
      "status": "portable-with-tool-contract"
    },
    "research/claim-verify": {
      "role": "research-team",
      "status": "portable-with-tool-contract"
    },
    "research/fact-check": {
      "role": "research-team",
      "status": "portable-persona"
    },
    "research/plan-review": {
      "role": "research-team",
      "status": "portable-persona"
    },
    "research/research-survey": {
      "role": "research-team",
      "status": "portable-persona"
    }
  },
  "packs": {
    "core": {
      "requires": [],
      "capabilities": [
        "autopilot-code"
      ]
    },
    "design": {
      "requires": [],
      "capabilities": [
        "autopilot-design"
      ]
    },
    "operations": {
      "requires": [],
      "capabilities": [
        "analyze-user",
        "audit",
        "autopilot-note",
        "post-it"
      ]
    },
    "research-writing": {
      "requires": [],
      "capabilities": [
        "analyze-project",
        "autopilot-apply",
        "autopilot-draft",
        "autopilot-refine",
        "autopilot-research"
      ]
    },
    "software": {
      "requires": [
        "core"
      ],
      "capabilities": [
        "analyze-project",
        "autopilot-lab",
        "autopilot-ship",
        "autopilot-spec"
      ]
    }
  },
  "profiles": {
    "builder": {
      "summary": "Analyze, specify, implement, verify, and retain project memory without the document/design specialist surface.",
      "packs": [
        "software",
        "operations"
      ]
    },
    "full": {
      "summary": "Expose every built-in capability and portable role.",
      "packs": [
        "core",
        "software",
        "research-writing",
        "design",
        "operations"
      ],
      "roles": [
        "external-adversary"
      ]
    },
    "starter": {
      "summary": "Run the golden code task with the code pipeline and mandatory kernel guards.",
      "packs": [
        "core"
      ]
    }
  },
  "kernel": {
    "always_on": [
      "instructions",
      "source-of-truth-rules",
      "write-and-spec-guards",
      "hook-config",
      "memory-contract"
    ],
    "agents": [
      "memory-scout"
    ]
  },
  "ownership": {
    "generated": [
      "manifest.json",
      "capabilities/README.md#catalog",
      "roles/README.md#role-catalog",
      "capabilities/*#capability-contract",
      "adapters/claude/skills/*/SKILL.md#frontmatter",
      "adapters/codex/skills/*/SKILL.md",
      "adapters/codex/agents/*.toml",
      "adapters/codex/modes/**/*.md",
      "adapters/opencode/skills/*/SKILL.md",
      "adapters/opencode/commands/*.md",
      "adapters/opencode/agents/**/*.md"
    ],
    "adapter_owned": [
      "adapters/claude/skills/*/SKILL.md#body",
      "adapters/claude/agents/*.md",
      "adapters/*/bin/*",
      "adapters/*/hooks/*",
      "adapters/*/ADAPTATION.md",
      "runtime-specific fallback and unsupported mappings"
    ]
  }
}
