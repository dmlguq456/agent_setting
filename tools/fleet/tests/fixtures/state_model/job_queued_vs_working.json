{
  "_case": "F-15c cross-rule — the SAME registry-only `open` row resolves differently on tier-3 evidence alone: a transcript exists (it really started) → working; no transcript yet but still inside the 15-min grace → queued (genuinely not started, not dead).",
  "kind": "job_pair",
  "now": 1000.0,
  "cases": [
    {
      "_case": "open + transcript present → working",
      "input": {"source": "jobs", "key": "code", "is_loop": false, "harness": "claude",
                "status": "open", "elapsed_min": 5, "slug": "wf-a", "transcript": "working"},
      "expect": {"state": "working", "tier": 3, "raw_status": "open"}
    },
    {
      "_case": "open + no transcript + elapsed 5min <= 15min grace → queued",
      "input": {"source": "jobs", "key": "code", "is_loop": false, "harness": "claude",
                "status": "open", "elapsed_min": 5, "slug": "wf-b", "transcript": "dead"},
      "expect": {"state": "queued", "tier": 3, "raw_status": "open"}
    },
    {
      "_case": "open + no transcript + elapsed 30min past grace → dead",
      "input": {"source": "jobs", "key": "code", "is_loop": false, "harness": "claude",
                "status": "open", "elapsed_min": 30, "slug": "wf-c", "transcript": "dead"},
      "expect": {"state": "dead", "tier": 3, "raw_status": "open"}
    }
  ]
}
