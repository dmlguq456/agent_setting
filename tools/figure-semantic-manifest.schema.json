{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/schemas/figure-semantic-manifest-v1.json",
  "title": "Report spectrogram semantic evidence manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile", "figure_groups", "metrics", "claims"],
  "properties": {
    "schema_version": {"const": 1},
    "profile": {"const": "spectrogram-report-48k-full-band"},
    "figure_groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id", "kind", "png_path", "sample_rate_hz", "min_hz", "max_hz",
          "dynamic_range_db", "shared_scale_per_figure", "colormap", "panels",
          "visual_review"
        ],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "kind": {"const": "spectrogram"},
          "png_path": {"type": "string", "minLength": 1},
          "sample_rate_hz": {"const": 48000},
          "min_hz": {"const": 0},
          "max_hz": {"const": 24000},
          "dynamic_range_db": {"type": "number", "exclusiveMinimum": 0},
          "shared_scale_per_figure": {"const": true},
          "colormap": {"type": "string", "minLength": 1},
          "panels": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "vmin_db", "vmax_db"],
              "properties": {
                "id": {"type": "string", "minLength": 1},
                "vmin_db": {"type": "number"},
                "vmax_db": {"type": "number"}
              }
            }
          },
          "visual_review": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "reviewed_png", "png_sha256", "reviewer", "reviewed_at", "evidence",
              "y_axis_0_24khz", "ticks_readable", "colorbar_present",
              "shared_scale_confirmed", "labels_readable"
            ],
            "properties": {
              "reviewed_png": {"type": "string", "minLength": 1},
              "png_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "reviewer": {"type": "string", "minLength": 1},
              "reviewed_at": {"type": "string", "format": "date-time"},
              "evidence": {"type": "string", "minLength": 1},
              "y_axis_0_24khz": {"const": true},
              "ticks_readable": {"const": true},
              "colorbar_present": {"const": true},
              "shared_scale_confirmed": {"const": true},
              "labels_readable": {"const": true}
            }
          }
        }
      }
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "min_hz", "max_hz"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "min_hz": {"type": "number", "minimum": 0},
          "max_hz": {"type": "number", "exclusiveMinimum": 0, "maximum": 24000}
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text", "type", "evidence"],
        "properties": {
          "id": {"type": "string", "pattern": "^claim-[0-9a-f]{16}$"},
          "text": {"type": "string", "minLength": 1},
          "type": {"enum": ["full_band", "broadband", "high_frequency"]},
          "claimed_band_hz": {
            "type": "array",
            "prefixItems": [
              {"type": "number", "minimum": 0, "maximum": 24000},
              {"type": "number", "minimum": 0, "maximum": 24000}
            ],
            "minItems": 2,
            "maxItems": 2
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "id"],
              "properties": {
                "kind": {"enum": ["figure_group", "metric"]},
                "id": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    }
  }
}
